{
	"name": "eleventy-plugin-icons",
	"version": "4.6.0",
	"description": "A plugin for Eleventy to add and transform icons from any icon set.",
	"author": "uncenter <hi@uncenter.dev>",
	"repository": "uncenter/eleventy-plugin-icons",
	"license": "MIT",
	"files": [
		"LICENSE",
		"README.md",
		"dist/"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		}
	},
	"type": "module",
	"scripts": {
		"build": "tsdown",
		"test": "vitest",
		"bench": "vitest bench",
		"lint": "biome lint .",
		"format": "biome check --write ."
	},
	"keywords": [
		"11ty",
		"eleventy",
		"eleventy-plugin"
	],
	"dependencies": {
		"fast-xml-parser": "^4.4.0",
		"just-typeof": "^3.2.0",
		"kleur": "^4.1.5",
		"merge": "^2.1.1"
	},
	"devDependencies": {
		"@11ty/eleventy": "3.0.0",
		"@biomejs/biome": "2.5.0",
		"@types/node": "^22.13.11",
		"lucide-static": "^0.483.0",
		"tsdown": "^0.22.2",
		"typescript": "^5.8.2",
		"vitest": "^3.0.9"
	},
	"engines": {
		"node": ">=16.20.2"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": ">=11.0.0 <12.0.0",
			"onFail": "error"
		}
	}
}
